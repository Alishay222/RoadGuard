# Copy this file to .env and fill in your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=roadguard

# Server Configuration
# For local testing only: set to 127.0.0.1
# For network access (mobile, remote clients): set to 0.0.0.0
HOST=0.0.0.0
PORT=8000

# Gemini Chatbot Configuration
# Create a key in Google AI Studio, then add it to backend/.env.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
